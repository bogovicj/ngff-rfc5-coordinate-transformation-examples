                },
                {
                    "name": "transformation between physical coordinate systems",
                    "type": "displacements",
                    "path": "physical-to-physical"
                },
                {
                    "name": "target physical to target pixel",
                    "type": "scale",
                    "scale": [5, 5]
                }
            ]

          }
        ]
      }
    }
  }
